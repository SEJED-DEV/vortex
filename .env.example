# Vortex Bot Configuration
# Follow the instructions below to obtain the required keys for each AI provider.

# [REQUIRED] Discord Bot Token
# Get yours at: https://discord.com/developers/applications
# Create an application, go to the 'Bot' tab, and click 'Reset Token' to reveal it.
DISCORD_TOKEN=

# [RECOMMENDED] Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
# Provides access to Gemini 1.5 Flash (Primary Agent).
GEMINI_API_KEY=

# [OPTIONAL] OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
# Provides access to GPT-4o.
OPENAI_API_KEY=

# [OPTIONAL] Anthropic Claude API Key
# Get yours at: https://console.anthropic.com/settings/keys
# Provides access to Claude 3.5 Sonnet.
CLAUDE_API_KEY=

# [OPTIONAL] OpenRouter API Key
# Get yours at: https://openrouter.ai/keys
# Provides access to 10+ agents (Llama 3, Claude 3 Opus, etc.).
OPENROUTER_API_KEY=

# [OPTIONAL] Groq API Key
# Get yours at: https://console.groq.com/keys
# Provides access to Mixtral 8x7b with high speed.
GROQ_API_KEY=

# [OPTIONAL] Mistral AI API Key
# Get yours at: https://console.mistral.ai/api-keys/
# Provides access to Mistral Large.
MISTRAL_API_KEY=
