# ==========================================
# 🌪️ VORTEX MANAGER - MASTER CONFIGURATION
# ==========================================
# Welcome to the Vortex Configuration file.
# Every aspect of the bot's branding, API access, and security
# can be controlled directly from this file.
# ==========================================

# ------------------------------------------
# [REQUIRED] CORE DISCORD CONFIGURATION
# ------------------------------------------
# The secret token for your Discord Bot (from Discord Developer Portal).
# NEVER share this token with anyone.
DISCORD_TOKEN=your_bot_token_here

# ------------------------------------------
# [CUSTOMIZATION] BOT BRANDING
# ------------------------------------------
# Change the bot's primary identity here! These variables will
# automatically update all embeds, footers, and AI responses.
BOT_NAME=Vortex
EMBED_COLOR=#1E90FF
EMBED_FOOTER_TEXT=Powered by Vortex Engine

# ------------------------------------------
# [RECOMMENDED] FREE-TIER AI PROVIDERS
# ------------------------------------------
# Vortex is designed to use free, high-speed APIs for reasoning.
# You only need ONE of these to be active, but adding both is best
# for the multi-model fallback system.

# Groq provides lightning-fast Llama 3 models (Highly Recommended)
# Get a free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here

# Google Gemini provides excellent reasoning and multimodal (image) support.
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_key_here

# ------------------------------------------
# [OPTIONAL] PAID AI PROVIDERS (OPENROUTER)
# ------------------------------------------
# If you want access to premium models like GPT-4o or Claude 3.5 Sonnet,
# you can use an OpenRouter API key. Vortex will prioritize this if present.
# Get a key at: https://openrouter.ai/
OPENROUTER_API_KEY=

# ------------------------------------------
# [OPTIONAL] DEVELOPER & SYSTEM SETTINGS
# ------------------------------------------
# Used to authenticate automatic GitHub synchronization and patching.
INTERNAL_AUTH_KEY=your_secure_auth_key
GITHUB_REPO=SEJED-DEV/vortex

# Toggle these to "false" to hide the AI model name or Skill name from the footer.
SHOW_AI_MODEL=true
SHOW_SKILL_USED=true
